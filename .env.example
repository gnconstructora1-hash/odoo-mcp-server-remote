# Odoo connection
ODOO_URL=https://your-odoo-instance.com
ODOO_DB=your_database
ODOO_USERNAME=admin
ODOO_PASSWORD=admin
# ODOO_API_KEY=your_api_key  # Alternative to password
ODOO_VERIFY_SSL=false
ODOO_TIMEOUT=120

# Optional: custom headers for Odoo (e.g., API gateway auth)
# ODOO_CUSTOM_HEADER_NAME=X-API-KEY
# ODOO_CUSTOM_HEADER_VALUE=your_value

# MCP server settings
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_API_KEY=your-secret-api-key-here
